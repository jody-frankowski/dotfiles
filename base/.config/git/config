[core]
	pager = less -F # Don't page if the output is shorter than the terminal height
[init]
	defaultBranch = main
[pull]
	rebase = true
[push]
	default = simple
	autoSetupRemote = true
[rebase]
	autoStash = true
[rerere]
	enabled = true
[magithub]
	online = false
[magithub "status"]
	includeStatusHeader = false
	includePullRequestsSection = false
	includeIssuesSection = false
[pager]
	stash = false
[mailmap]
	file = ~/.config/git/mailmap
[diff]
	noPrefix = true
[color "diff"]
	old = bold red
	new = bold green

[alias]
  a  = add
  b  = branch
  c  = commit -v -m
  co = checkout
  d  = diff
  f  = fetch --all --prune --tags
  l  = pull --tags
  p  = push --follow-tags # Only push annotated tags
  r  = remote
  rv = r -v
  sh = show
  st = status -sb

  bb = bisect bad
  bg = bisect good
  br = bisect reset
  bs = bisect start

  lo  = log    --abbrev=6 --date='format:%y-%m-%d' --format=format:'%C(bold blue)%h%C(reset) %C(bold green)%ad%C(reset) %C(blue)%aN%C(reset) %C(white)%s%C(reset) %C(auto)%(decorate:pointer=->,prefix=,suffix=,tag=,separator= )%C(reset)'
  lop = log -p --abbrev=6 --date='format:%y-%m-%d' --format=format:'%C(bold blue)%h%C(reset) %C(bold green)%ad%C(reset) %C(blue)%aN%C(reset) %C(auto)%(decorate:pointer=->,prefix=,suffix=,tag=,separator= )%C(reset)%n%B'
  loa = lo --all --graph

  s   = stash
  sa  = s apply --index
  sl  = -c log.date='format:%y-%m-%d %H:%M' stash list --format=format:'%C(bold blue)%gd%C(reset) %C(bold green)%ad%C(reset) %C(white)%s%C(reset)'
  sp  = s push -u
  spa = !git sp && git sa
  ss  = s show -u
  ssp = ss -p

  su  = submodule
  suf = su foreach
  sus = su sync
  suu = su update

[include]
	path = ~/.config/git/config-private
[includeIf "gitdir:~/Dev/**"]
	path = ~/Dev/.gitconfig
[includeIf "gitdir:~/Dev/me/**"]
	path = ~/Dev/me/.gitconfig
[includeIf "gitdir:~/Dev/work/**"]
	path = ~/Dev/work/.gitconfig
