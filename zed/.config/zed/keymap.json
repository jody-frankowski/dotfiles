// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": { "shift shift": "command_palette::Toggle" },
  },
  {
    "context": "Terminal",
    "bindings": { "cmd-b": ["terminal::SendText", "\u001bb"] },
  },
  {
    "context": "Terminal",
    "bindings": { "cmd-f": ["terminal::SendText", "\u001bf"] },
  },
  {
    "bindings": { "cmd-0": "terminal_panel::Toggle" },
  },
  {
    "context": "Terminal",
    "bindings": { "escape": "editor::ToggleFocus" },
  },
  {
    "context": "VimControl && !menu && vim_mode == normal",
    "bindings": {
      "space c y y": ["workspace::SendKeystrokes", "y y g c c p"],
    },
  },
  {
    "context": "VimControl && !menu && vim_mode == visual",
    "bindings": {
      "space c y": ["workspace::SendKeystrokes", "y g v g c ' > p"],
    },
  },
]
