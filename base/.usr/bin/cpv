#!/bin/zsh

set -euo pipefail

if [[ $# -lt 2 || $1 == -h || $1 == --help ]]; then
    echo "Usage: $(basename $0) [RSYNC_OPTIONS] FILE|DIR... DESTINATION" >&2
    echo 'Copies files and directories.' >&2
    exit 1
fi

# --old-args: On Linux and macOS, the default rsync installed completion complete remote paths with
# triple backslash escaped spaces while the recent rsync versions accept single escaped args.
# Note that with this config, quoted spaces in paths will need to be single escaped.
exec rsync --old-args -avPih "$@"
